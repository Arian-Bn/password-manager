<file path="CMakeLists.txt">
cmake_minimum_required(VERSION 3.16)
project(PasswordManager VERSION 1.0.0 LANGUAGES CXX)

# C++20 стандарт
set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

# Пути для заголовочных файлов
include_directories(${CMAKE_CURRENT_SOURCE_DIR}/include)

# Исходные файлы
set(SOURCES
    src/main.cpp
    src/PasswordEntry.cpp
    src/CreditCardEntry.cpp
)

# Исполняемый файл
add_executable(password_manager ${SOURCES})

# Опции компиляции для разных платформ
if(MSVC)
    target_compile_options(password_manager PRIVATE /W4 /WX)
else()
    target_compile_options(password_manager PRIVATE -Wall -Wextra -Wpedantic -Werror)
endif()
</file>

<file path="src/main.cpp">
#include "../include/CreditCardEntry.hpp"
#include "../include/PasswordEntry.hpp"
#include <iostream>

int main() {
  // 1. СОЗДАНИЕ объектов
  PasswordEntry password("GitHub", "myLogin", "myPassword123");
  CreditCardEntry card("4111111111111111", "IVAN IVANOV", "12/25", "123");

  // 2. ТЕСТИРОВАНИЕ методов
  std::cout << "Password encrypted: " << password.encrypt() << std::endl;
  std::cout << "Card encrypted: " << card.encrypt() << std::endl;

  // 3. Проверка геттеров (опционально)
  std::cout << "\nCard holder: " << card.getCardHolderName() << std::endl;
  std::cout << "Service: " << password.getService() << std::endl;

  return 0;
}
</file>

<file path="README.md">
# Password Manager

C++20 password manager with client-server architecture.

## Build Instructions

```bash
mkdir build && cd build
cmake .. -DCMAKE_BUILD_TYPE=Release
cmake --build . --parallel
./password_manager
</file>

<file path="include/PasswordEntry.hpp">
#pragma once
#include "Secret.hpp"
#include <string>

class PasswordEntry : public Secret {
private:
  std::string service;
  std::string login;
  std::string password;

public:
  PasswordEntry(std::string service, std::string login, std::string password)
      : service(service), login(login), password(password) {}
  virtual std::string encrypt() const override;

  std::string getService() const { return service; }

  std::string getLogin() const { return login; }

  std::string getPassword() const { return password; }
};
</file>

<file path="include/Secret.hpp">
#pragma once
#include <string>

class Secret {
public:
  virtual std::string encrypt() const = 0;
  virtual ~Secret() = default;
};
